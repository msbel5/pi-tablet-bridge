#!/usr/bin/env sh

set -eu

APP_HOME=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
GRADLE_VERSION=6.7.1
DIST_NAME="gradle-${GRADLE_VERSION}"
DIST_ZIP="${APP_HOME}/.gradle-bootstrap/${DIST_NAME}-bin.zip"
DIST_DIR="${APP_HOME}/.gradle-bootstrap/${DIST_NAME}"
GRADLE_BIN="${DIST_DIR}/bin/gradle"

if [ -z "${JAVA_HOME:-}" ]; then
  for candidate in /usr/lib/jvm/java-11-openjdk-amd64 /usr/lib/jvm/java-1.11.0-openjdk-amd64; do
    if [ -x "${candidate}/bin/java" ]; then
      JAVA_HOME="${candidate}"
      export JAVA_HOME
      PATH="${JAVA_HOME}/bin:${PATH}"
      export PATH
      break
    fi
  done
fi

if [ ! -x "${GRADLE_BIN}" ]; then
  mkdir -p "${APP_HOME}/.gradle-bootstrap"
  if [ ! -f "${DIST_ZIP}" ]; then
    curl -L --fail --output "${DIST_ZIP}" "https://services.gradle.org/distributions/${DIST_NAME}-bin.zip"
  fi
  rm -rf "${DIST_DIR}"
  mkdir -p "${DIST_DIR}"
  (
    cd "${APP_HOME}/.gradle-bootstrap"
    rm -rf "${DIST_NAME}"
    jar xf "${DIST_ZIP}"
  )
fi

exec "${GRADLE_BIN}" "$@"
